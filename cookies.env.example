# Hanako Audio Player - Cookie 配置模板
#
# 复制本文件为 cookies.env，填入你自己的 cookie 值。
# cookies.env 不会上传到 Git（已被 .gitignore 排除）。
#
# ── 网易云音乐 (NetEase) ──
# 1. 浏览器登录 music.163.com
# 2. F12 → Application → Cookies → 找到 MUSIC_U 和 __csrf
# 3. 拼接成 cookie 字符串，格式：
#    MUSIC_U=你的MUSIC_U值; __csrf=你的__csrf值
#
# 没有配置 cookie 时，在线歌曲只能播放 30 秒预览。

NETEASE_COOKIE=
TENCENT_COOKIE=
